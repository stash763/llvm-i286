     1                                  ; NASM example to create a 16-bit OS/2 segmented NE executable
     2                                  
     3                                  
     4                                  BITS 16
     5                                  
     6                                  cr		equ 0x0d
     7                                  lf		equ 0x0a
     8                                  stdin		equ 0
     9                                  stdout		equ 1
    10                                  
    11                                  group DGROUP _DATA
    12                                  
    13                                          	extern   DosExit
    14                                  	        extern   DosRead
    15                                  	        extern   DosWrite
    16                                                  extern	 DosAllocSeg
    17                                  
    18                                  
    19                                  segment _DATA CLASS=DATA 			; Static data
    20                                  
    21 00000000 48656C6C6F20576F72-     msg1		db 'Hello World',cr,lf
    22 00000009 6C640D0A           
    23                                  msg1_len	equ $-msg1
    24                                  
    25 0000000D <res 0000000C>          num1		resb 12
    26                                  
    27 00000019 0000                    num_start	dw 0
    28 0000001B 0000                    num_len		dw 0
    29                                  
    30 0000001D 0000                    rlen		dw 0
    31 0000001F 0000                    wlen		dw 0
    32                                  
    33 00000021 A0860100                n1		dd 100000
    34 00000025 A1860100                n2		dd 100001
    35 00000029 00000000                nresult		dd 0
    36                                  
    37                                  segment	STACK STACK
    38                                  		; this is defined in .def file
    39 00000000 <res 00001000>          		resb 4096
    40                                  
    41                                  
    42                                  segment _TEXT CLASS=CODE
    43                                  
    44 00000000 89E5                    ..start:        mov 	bp,sp
    45                                  
