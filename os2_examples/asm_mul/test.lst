     1                                  ; NASM example to create a 16-bit OS/2 segmented NE executable
     2                                  
     3                                  
     4                                  BITS 16
     5                                  
     6                                  cr		equ 0x0d
     7                                  lf		equ 0x0a
     8                                  stdin		equ 0
     9                                  stdout		equ 1
    10                                  true		equ 1
    11                                  false		equ 0
    12                                  
    13                                  group DGROUP _DATA
    14                                  
    15                                          	extern   DosExit
    16                                  	        extern   DosRead
    17                                  	        extern   DosWrite
    18                                                  extern	 DosAllocSeg
    19                                  
    20                                  
    21                                  segment _DATA CLASS=DATA 			; Static data
    22                                  
    23 00000000 48656C6C6F20576F72-     msg1		db 'Hello World',cr,lf
    24 00000009 6C640D0A           
    25                                  msg1_len	equ $-msg1
    26                                  
    27 0000000D 506F7369746976650D-     msg_pos		db 'Positive',cr,lf
    28 00000016 0A                 
    29                                  msg_pos_len	equ $-msg_pos
    30                                  
    31 00000017 4E656761746976650D-     msg_neg		db 'Negative',cr,lf
    32 00000020 0A                 
    33                                  msg_neg_len	equ $-msg_neg
    34                                  
    35 00000021 <res 0000000C>          num1		resb 12
    36                                  
    37 0000002D 0000                    num_start	dw 0
    38 0000002F 0000                    num_len		dw 0
    39                                  
    40 00000031 0000                    rlen		dw 0
    41 00000033 0000                    wlen		dw 0
    42 00000035 A0860100                n1		dd 100000
    43 00000039 FEFFFFFF                n2		dd -2
    44 0000003D 00000000                nresult		dd 0
    45                                  
    46                                  segment	STACK STACK
    47                                  		; this is defined in .def file
    48 00000000 <res 00001000>          		resb 4096
    49                                  
    50                                  
    51                                  segment _TEXT CLASS=CODE
    52                                  
    53 00000000 89E5                    ..start:        mov 	bp,sp
    54                                  
    55 00000002 BF0000                  multiply:      	mov	di,false       		; set false
    56                                  
    57                                  		; num1 = n1
    58 00000005 A1[3500]                                mov	ax,[n1]
    59 00000008 8B1E[3700]                              mov	bx,[n1 + 2]
    60                                  
    61                                                  ; num2 = n2
    62 0000000C 8B0E[3900]                              mov	cx,[n2]
    63 00000010 8B16[3B00]                              mov	dx,[n2 + 2]
    64                                  		
    65                                  		; Test if the answer is +/-
    66                                                  ; change all negative numbers to postive
    67 00000014 83FB00                                  cmp	bx,0			; if (num1 < 0)
    68 00000017 7C02                                    jl	t1_neg
    69 00000019 EB0A                                    jmp	t1_pos
    70 0000001B BF0100                  t1_neg:         mov	di,true			; set true if negative
    71 0000001E F7DB                    		neg	bx			; num1 = -num1
    72 00000020 F7D8                    		neg	ax
    73 00000022 83DB00                                  sbb	bx,0
    74 00000025 83FA00                  t1_pos:		cmp	dx,0			; if (num2 < 0)
    75 00000028 7C02                                    jl	t2_neg
    76 0000002A EB0A                                    jmp	t2_pos
    77 0000002C 83F701                  t2_neg:		xor	di,true			; if true already becomes false
    78 0000002F F7DA                    		neg	dx			; num2 = -num2
    79 00000031 F7D9                    		neg	cx
    80 00000033 83DA00                                  sbb	dx,0
    81                                  
    82 00000036 57                      t2_pos:		push	di			; Save sign result to stack
    83                                  
    84 00000037 31FF                    		xor	di,di			; result = 0
    85 00000039 31F6                                    xor	si,si
    86                                  
    87 0000003B 83F900                  mul_start:     	cmp	cx,0			; while (num2 > 0)
    88 0000003E 7503                                    jne	comp32_end
    89 00000040 83FA00                                  cmp	dx,0
    90 00000043 7502                    comp32_end:	jnz	mul_cont
    91 00000045 EB14                    		jmp	mul_end
    92                                  
    93 00000047 F7C10100                mul_cont:	test	cx,1			; if num2 & 0x0001
    94 0000004B 7404                    		je	skip_add
    95                                  
    96 0000004D 01DE                                    add	si,bx  			; result += num1
    97 0000004F 11C7                                    adc	di,ax
    98                                  
    99 00000051 D1E0                    skip_add:	shl	ax,1			; num1 <<= 1
   100 00000053 D1D3                    		rcl	bx,1
   101                                  
   102 00000055 D1F9                                    sar	cx,1			; num2 >>= 1
   103 00000057 D1DA                                    rcr	dx,1
   104                                  
   105 00000059 EBE0                                    jmp	mul_start
   106                                  mul_end:	; result is in di:si
   107                                  
   108 0000005B 58                      		pop	ax			; is negative = true
   109 0000005C 83F801                                  cmp	ax,true
   110 0000005F 7507                                    jne	mul_done
   111                                  
   112 00000061 F7DE                                    neg si
   113 00000063 F7DF                                    neg di
   114 00000065 83DE00                                  sbb si,0
   115                                  
   116                                                  
   117                                  mul_done:
   118                                  		; change sign of number
   119                                  
   120                                                  ; print the number
   121                                  
   122                                  		; Convert a number to a string
   123                                                  ; the following parameters are return values
   124 00000068 1E                                      push	ds                      ; beginning of string
   125 00000069 68[2D00]                                push	num_start
   126 0000006C 1E                                      push	ds			; length of string 
   127 0000006D 68[2F00]                                push	num_len
   128                                                  ; Input parameters
   129                                                  ;push	dx			; push MSB
   130                                                  ;push	cx		        ; push LSB
   131 00000070 56                                      push	si			; MSB
   132 00000071 57                                      push	di			; LSB
   133 00000072 1E                                      push	ds                      ; far pointer to buffer
   134 00000073 68[2100]                                push	num1 
   135 00000076 9A[9B00][0000]          		call	far itoa
   136 0000007B 83C410                                  add	sp,16			; clean up the stack pointer
   137                                  
   138                                  		; display the string
   139 0000007E 6A01                                    push	stdout
   140 00000080 1E                                      push	ds
   141 00000081 A1[2D00]                                mov	ax,[num_start]
   142 00000084 50                                      push	ax
   143 00000085 A1[2F00]                                mov 	ax,[num_len]
   144 00000088 50                                      push 	ax
   145 00000089 1E                                      push	ds
   146 0000008A 68[3300]                                push	wlen
   147 0000008D 9A[0000][0000]                          call	far DosWrite
   148                                  
   149                                  exit:
   150 00000092 6A01                    		push    1               	; terminate process
   151 00000094 6A00                    		push    0               	; return code
   152 00000096 9A[0000][0000]          		call	far DosExit
   153                                  
   154                                                  ; *********** Convert integer to string ***********
   155                                  		;
   156                                                  ; ==== Call parameters on stack
   157                                                  ;
   158                                  		; 4 bytes - return address
   159                                                  ; 4 bytes - pointer to buffer
   160                                                  ; 4 bytes - 32-bit number
   161                                                  ; 4 bytes - pointer to dw number length
   162                                                  ; 4 bytes - pointer to dw string start
   163                                  
   164 0000009B 89E5                    itoa:           mov bp,sp			; save the current stack pointer
   165 0000009D 83C404                  		add sp,4			; move to the start of parameters
   166                                  
   167 000000A0 5F                      		pop di				; far pointer to buffer
   168 000000A1 07                      		pop es
   169                                  
   170 000000A2 5B                                      pop bx				; load the 32-bit integer
   171 000000A3 5A                                      pop dx
   172                                  
   173 000000A4 B90B00                                  mov cx,0x000b
   174 000000A7 B020                                    mov al,' '
   175 000000A9 F3AA                                    repz stosb
   176 000000AB 26880D                                  mov [es:di],cl
   177 000000AE 57                                      push di				; end of the string
   178 000000AF 89D8                                    mov ax,bx
   179 000000B1 BE0A00                                  mov si,0x000a
   180 000000B4 09D2                                    or dx,dx
   181 000000B6 9C                                      pushf
   182 000000B7 790A                                    jns lts_cont
   183 000000B9 F7D0                                    not ax
   184 000000BB F7D2                                    not dx
   185 000000BD 83C001                                  add ax,1
   186 000000C0 83D200                                  adc dx,+00
   187                                  
   188 000000C3 89C1                    lts_cont:       mov cx,ax
   189 000000C5 89D0                    		mov ax,dx
   190 000000C7 31D2                                    xor dx,dx
   191 000000C9 F7F6                                    div si
   192 000000CB 89C3                                    mov bx,ax
   193 000000CD 89C8                                    mov ax,cx
   194 000000CF F7F6                                    div si
   195 000000D1 87D3                                    xchg dx,bx
   196 000000D3 80C330                                  add bl,'0'
   197 000000D6 4F                                      dec di
   198 000000D7 26881D                                  mov [es:di],bl
   199 000000DA 89C3                                    mov bx,ax
   200 000000DC 09D3                                    or bx,dx
   201 000000DE 75E3                                    jnz lts_cont
   202 000000E0 4F                                      dec di
   203 000000E1 B020                                    mov al,' '
   204 000000E3 9D                                      popf
   205 000000E4 7907                                    jns notneg			; if not negative start exit
   206 000000E6 B02D                                    mov al,'-'
   207 000000E8 268805                                  mov [es:di],al
   208 000000EB EB01                                    jmp lts_exit			; '-' added exit now
   209 000000ED 47                      notneg:		inc di                          ; This wasn't negative move the start of string
   210                                  
   211 000000EE 5A                      lts_exit:       pop dx                          ; end of string
   212                                  
   213                                  		; TODO something is wrong here
   214                                                  ; pointers on stack are incorrect
   215                                  
   216 000000EF 5E                                      pop si				; get pointer to num_len
   217 000000F0 07                                      pop es		
   218 000000F1 29FA                    		sub dx,di			; find length
   219 000000F3 268914                                  mov [es:si],dx			; save length
   220                                  
   221 000000F6 5E                                      pop si
   222 000000F7 07                                      pop es
   223 000000F8 26893C                                  mov [es:si],di			; save start of string
   224                                  
   225 000000FB 89EC                                    mov sp,bp			; restore the stack pointer
   226 000000FD CB                      		retf
   227                                  
   228                                  segment _DATA
   229                                  
   230                                  segment end
